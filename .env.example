# VinoBuzz AI Photo Verifier - Environment Configuration
# Copy this file to .env and fill in your actual API keys

# Required: Gemini API key for vision verification (HYBRID mode)
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: SerpAPI key for high-quality image search
# Get one at: https://serpapi.com/
SERPAPI_KEY=your_serpapi_key_here

# Optional: OpenRouter API key for Qwen-VL verification fallback
# Get one at: https://openrouter.ai/
OPENROUTER_API_KEY=your_openrouter_key_here

# Optional: Session ID for VinoBuzz marketplace scraping
# Only needed if you want to refresh the live catalog
VINOBUZZ_SESSION_ID=your_session_id_here

# Application URL (for OpenRouter HTTP-Referer header)
APP_URL=http://localhost:3000
