# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# OPENROUTER_API_KEY: Used for Qwen-VL verification via OpenRouter
OPENROUTER_API_KEY="MY_OPENROUTER_API_KEY"

# SERPAPI_KEY: Key for real web search (SerpApi)
SERPAPI_KEY="MY_SERPAPI_KEY"

# BRAVE_SEARCH_API_KEY: (Optional) High-quality privacy-first search API
BRAVE_SEARCH_API_KEY="MY_BRAVE_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# VINOBUZZ_SESSION_ID: Optional session ID for fetching private API data
VINOBUZZ_SESSION_ID="YOUR_SESSION_ID_HERE"
